@ECHO OFF
PROMPT $P$G
C:\DOS\MODE CON RATE=32 DELAY=1
LH C:\DOS\KILLER
REM Enable command history
LH C:\DOS\DOSKEY
REM LH C:\DOS\DOSLFN /Z:C:\DOS\CP437UNI.TBL
LH C:\DOS\SHSUCDX /D:SHSU-CD
REM Share is required for LFN support
REM LH C:\DOS\SHARE /L:30
REM LH C:\DOS\SMARTDRV
LH C:\DOS\CTMOUSE
REM For compatiblity purpose:
LH C:\DOS\CTMOUSE > NUL
REM For locking volumes to enable "direct disk access":
REM CALL C:\DOS\LOCKDRV.BAT
REM Enable CTRL+C checking for I/O
BREAK ON
REM C:\DOS\LFNFOR ON
SET PATH=C:\DOS;..;
SET TEMP=C:\TEMP
IF EXIST C:\SNDDRV\SOUND.BAT CALL C:\SNDDRV\SOUND.BAT
if errorlevel 1 pause
IF EXIST C:\DOS\TWEAKS.BAT CALL C:\DOS\TWEAKS.BAT
if errorlevel 1 pause
IF EXIST C:\NWCLIENT\START.BAT CALL C:\NWCLIENT\START.BAT
if errorlevel 1 pause
CLS
if exist 1STBOOT.MSG type 1STBOOT.MSG
if exist 1STBOOT.MSG del 1STBOOT.MSG
